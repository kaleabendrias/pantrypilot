# PantryPilot Environment Configuration
# Copy to .env and fill in all values before starting.

# Database credentials
DB_NAME=pantrypilot
DB_USER=
DB_PASS=
MYSQL_ROOT_PASSWORD=

# Application secrets (all required - startup fails without them)
PANTRYPILOT_GATEWAY_HMAC_SECRET=
PANTRYPILOT_CRYPTO_KEY=
PANTRYPILOT_CRYPTO_IV=
