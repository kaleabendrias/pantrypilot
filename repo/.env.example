# PantryPilot Environment Configuration
#
# This file documents every variable the stack consumes.
# The application does NOT ship any defaults for the secrets below.
#
# PANTRYPILOT_GATEWAY_HMAC_SECRET, PANTRYPILOT_CRYPTO_KEY, and
# PANTRYPILOT_CRYPTO_IV are generated automatically at container startup
# when left empty. Each container restart will produce new secrets, which
# means previously encrypted data will become unreadable and issued HMAC
# signatures will be invalid. For persistent deployments generate them
# once and keep them stable:
#
#   openssl rand -hex 32   → use for PANTRYPILOT_GATEWAY_HMAC_SECRET
#   openssl rand -hex 32   → use for PANTRYPILOT_CRYPTO_KEY
#   openssl rand -hex 8    → use for PANTRYPILOT_CRYPTO_IV

# ── Database ─────────────────────────────────────────────────────────────────
DB_NAME=pantrypilot
DB_USER=
DB_PASS=
MYSQL_ROOT_PASSWORD=

# ── Application secrets ───────────────────────────────────────────────────────
# Leave empty to auto-generate at container start (ephemeral).
# Set explicitly for persistent, production-grade deployments.
PANTRYPILOT_GATEWAY_HMAC_SECRET=
PANTRYPILOT_CRYPTO_KEY=
PANTRYPILOT_CRYPTO_IV=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins the API will accept cross-site requests from.
# Example: http://app.example.com,https://app.example.com
PANTRYPILOT_ALLOWED_ORIGINS=
